# .env.example — Template de variables de entorno
# Copia a .env y rellena los valores antes de iniciar.
# Las flags se generan automáticamente con: bash scripts/generate_flags.sh

# ── Flags ─────────────────────────────────────────────────────────────────────
FLAG_SQLI=CTF{placeholder_ejecuta_generate_flags}
FLAG_XSS=CTF{placeholder_ejecuta_generate_flags}
FLAG_SSTI=CTF{placeholder_ejecuta_generate_flags}
FLAG_CRYPTO_RSA=CTF{placeholder_ejecuta_generate_flags}
FLAG_CRYPTO_VIGENERE=CTF{placeholder_ejecuta_generate_flags}

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=cambia-esto-en-produccion-minimo-50-chars
JWT_SIGNING_KEY=cambia-esto-en-produccion-diferente-al-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1,tudominio.com
CORS_ORIGINS=http://localhost,https://tudominio.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=ctf_db
POSTGRES_USER=ctf_user
POSTGRES_PASSWORD=cambia-esto-en-produccion
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Docker / Instancias ───────────────────────────────────────────────────────
DOCKER_NETWORK=ctf-challenges-net
INSTANCE_TTL_MINUTES=30
PUBLIC_HOSTNAME=localhost   # IP o dominio público del servidor
# INSTANCE_URL_PATTERN=https://tudominio.com/retos/{port}/  # Opcional: para proxy por subdirectorios

# ── Conexión remota Docker (Opcional, usado en VPS de producción) ─────────────
# Dejar estas variables vacías/comentadas para usar el socket local (/var/run/docker.sock)
# tanto en desarrollo como en producción mono-servidor (Local).
#
# Para despliegues distribuidos en 2 VMs (Opción 1: Sin TLS por red privada local):
# DOCKER_HOST=tcp://IP_PRIVADA_VM2:2375
# DOCKER_TLS_VERIFY=
# DOCKER_CERT_PATH=
