---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeCTAs from "../components/react/HomeCTAs";
import HomeRegisterBtn from "../components/react/HomeRegisterBtn";

const categories = [
  {
    label: "Web",
    color: "#818cf8",
    bg: "rgba(129,140,248,0.08)",
    border: "rgba(129,140,248,0.2)",
    glow: "rgba(129,140,248,0.15)",
    count: 10,
    icon: `<svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>`,
    tags: ["SQLi", "XSS", "LFI", "SSTI", "JWT", "+5"],
    desc: "Explota vulnerabilidades reales en aplicaciones web — desde inyección SQL hasta bypass de autenticación con JWT.",
  },
  {
    label: "Crypto",
    color: "#f472b6",
    bg: "rgba(244,114,182,0.08)",
    border: "rgba(244,114,182,0.2)",
    glow: "rgba(244,114,182,0.15)",
    count: 2,
    icon: `<svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>`,
    tags: ["RSA", "Vigenère"],
    desc: "Rompe implementaciones criptográficas débiles. Factoriza módulos RSA y recupera claves de cifrado clásico.",
  },
  {
    label: "Forense",
    color: "#34d399",
    bg: "rgba(52,211,153,0.08)",
    border: "rgba(52,211,153,0.2)",
    glow: "rgba(52,211,153,0.15)",
    count: 2,
    icon: `<svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>`,
    tags: ["PCAP", "Esteganografía"],
    desc: "Analiza capturas de red y archivos para descubrir tráfico sospechoso y datos ocultos dentro de imágenes.",
  },
];

const featured = [
  { slug: "sqli",          cat: "Web",     color: "#818cf8", label: "SQLi",        title: "Inyección SQL",          pts: 100, desc: "Bypasea el login y exfiltra datos vía UNION." },
  { slug: "xss",           cat: "Web",     color: "#818cf8", label: "XSS",         title: "XSS Almacenado",         pts: 150, desc: "Inyecta JS en comentarios y roba la cookie del admin." },
  { slug: "jwt",           cat: "Web",     color: "#818cf8", label: "JWT",         title: "El Portal del Admin",    pts: 300, desc: "Forja un token JWT para acceder como administrador." },
  { slug: "crypto-rsa",    cat: "Crypto",  color: "#f472b6", label: "RSA",         title: "Claves Rotas — RSA",     pts: 250, desc: "Exponente e=3 y mensaje pequeño. Calcula la raíz cúbica." },
  { slug: "forensics-pcap",cat: "Forense", color: "#34d399", label: "PCAP",        title: "El Tráfico Comprometido",pts: 200, desc: "Filtra el tráfico capturado y reconstruye las credenciales." },
  { slug: "stego",         cat: "Forense", color: "#34d399", label: "Stego",       title: "La Imagen Silenciosa",   pts: 300, desc: "Extrae datos ocultos en los bits menos significativos." },
];

const steps = [
  {
    n: "01",
    title: "Regístrate",
    desc: "Crea tu cuenta institucional y únete a la competencia. Si hay equipos, crea el tuyo o únete con un código.",
    icon: `<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>`,
  },
  {
    n: "02",
    title: "Inicia el entorno",
    desc: "Cada reto corre en un contenedor Docker efímero. Un clic lo levanta, 30 minutos para explotarlo.",
    icon: `<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3l14 9-14 9V3z"/></svg>`,
  },
  {
    n: "03",
    title: "Captura la flag",
    desc: "Explota la vulnerabilidad, obtén la flag con formato CTF{...} y envíala para sumar puntos al marcador.",
    icon: `<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21V7l9-4 9 4v14M9 21V12h6v9"/></svg>`,
  },
];
---
<BaseLayout
  title="Inicio · CTF USFX"
  description="Plataforma de competencia CTF de la USFX — entornos Docker aislados, retos reales de ciberseguridad."
  fullWidth={true}
>

  <!-- ══════════════════════════════════════════════════════ HERO -->
  <section class="text-white relative overflow-hidden" style="background: radial-gradient(ellipse at 60% 50%, #5d3ecf 0%, #3d2c88 50%, #1a0f40 100%);">

    <!-- Grid overlay -->
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none"
      style="background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 36px 36px;">
    </div>

    <!-- Decorativo terminal (desktop) -->
    <div aria-hidden="true"
      class="absolute right-8 inset-y-0 hidden lg:flex flex-col justify-center gap-2 font-mono text-[11px] opacity-[0.07] select-none pointer-events-none text-right"
      style="color: white;">
      <div>$ nmap -sV --script vuln 10.0.0.1</div>
      <div>$ sqlmap -u "http://target/login" --dump</div>
      <div>$ john --wordlist=rockyou.txt hash.txt</div>
      <div>$ python3 rsa_exploit.py --e 3 --ct cipher</div>
      <div>$ binwalk -e stego_image.png</div>
      <div style="color: #FFEE58;">$ cat flag.txt</div>
    </div>

    <div class="container-page relative py-20 sm:py-28">

      <!-- Logo + badge USFX -->
      <div class="flex items-center gap-3 mb-10 animate-fade-in">
        <img
          src="/logo-usfx.png"
          alt="USFX"
          class="h-9 w-auto"
          style="filter: brightness(0) invert(1);"
        />
        <div class="w-px h-6" style="background: rgba(255,255,255,0.2);"></div>
        <span class="font-mono text-xs font-semibold px-2 py-1 rounded-md"
          style="background: rgba(255,238,88,0.12); color: #FFEE58; border: 1px solid rgba(255,238,88,0.25);">
          DTIC · Ciberseguridad
        </span>
      </div>

      <!-- Overline prompt -->
      <p class="font-mono text-xs mb-3 animate-slide-up" style="color: rgba(255,238,88,0.7); animation-delay: 40ms;">
        $ ssh competidor@ctf.usfx.bo
      </p>

      <!-- H1 -->
      <h1
        class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight max-w-2xl mb-5 tracking-tight animate-slide-up"
        style="animation-delay: 80ms;"
      >
        Competencia de<br/>
        <span style="color: #FFEE58;">Ciberseguridad</span> USFX
      </h1>

      <p
        class="text-base max-w-xl mb-9 leading-relaxed animate-slide-up"
        style="color: rgba(255,255,255,0.65); animation-delay: 160ms;"
      >
        14 retos reales en entornos Docker aislados — Web, Criptografía y Forense digital.
        Diseñados por la DTIC para formación práctica en seguridad informática.
      </p>

      <HomeCTAs client:load />

    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ STATS BAR -->
  <div style="background: #120b2e; border-bottom: 1px solid rgba(99,102,241,0.18);">
    <div class="container-page py-5">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 sm:gap-0 sm:divide-x animate-fade-in"
        style="animation-delay: 280ms; --tw-divide-opacity: 0.12; divide-color: rgba(99,102,241,var(--tw-divide-opacity));">
        <div class="sm:px-8 first:pl-0">
          <p class="text-2xl font-black font-mono" style="color: #FFEE58;">14</p>
          <p class="text-xs font-medium mt-0.5" style="color: rgba(255,255,255,0.45);">Retos disponibles</p>
        </div>
        <div class="sm:px-8">
          <p class="text-2xl font-black font-mono" style="color: #818cf8;">3</p>
          <p class="text-xs font-medium mt-0.5" style="color: rgba(255,255,255,0.45);">Categorías</p>
        </div>
        <div class="sm:px-8">
          <p class="text-2xl font-black font-mono" style="color: #34d399;">Docker</p>
          <p class="text-xs font-medium mt-0.5" style="color: rgba(255,255,255,0.45);">Entornos aislados</p>
        </div>
        <div class="sm:px-8">
          <p class="text-2xl font-black font-mono" style="color: #f472b6;">USFX</p>
          <p class="text-xs font-medium mt-0.5" style="color: rgba(255,255,255,0.45);">DTIC · Chuquisaca</p>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════ CATEGORÍAS -->
  <section class="container-page py-16 reveal">
    <div class="mb-8">
      <p class="font-mono text-xs mb-1" style="color: var(--primary);">$ ls -la ./challenges/</p>
      <h2 class="text-2xl font-bold tracking-tight" style="color: var(--text);">Categorías de retos</h2>
      <p class="text-sm mt-1" style="color: var(--text-muted);">Tres áreas de especialización para entrenar habilidades defensivas y ofensivas.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 stagger-children">
      {categories.map(cat => (
        <a
          href={`/challenges#${cat.label.toLowerCase()}`}
          class="card-hover rounded-xl p-6 block group transition-all duration-200"
          style={`background: var(--surface); border: 1px solid var(--border);`}
        >
          <!-- Icon + count -->
          <div class="flex items-start justify-between mb-4">
            <span
              class="inline-flex items-center justify-center w-11 h-11 rounded-xl"
              style={`background: ${cat.bg}; border: 1px solid ${cat.border}; color: ${cat.color};`}
              set:html={cat.icon}
            />
            <span
              class="font-mono font-black text-xl"
              style={`color: ${cat.color};`}
            >
              {cat.count}
            </span>
          </div>

          <!-- Label -->
          <p class="font-bold text-base mb-1.5" style="color: var(--text);">{cat.label}</p>
          <p class="text-xs leading-relaxed mb-4" style="color: var(--text-muted);">{cat.desc}</p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-1.5">
            {cat.tags.map(tag => (
              <span
                class="text-[11px] font-mono font-semibold px-2 py-0.5 rounded"
                style={`background: ${cat.bg}; color: ${cat.color}; border: 1px solid ${cat.border};`}
              >
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ CÓMO FUNCIONA -->
  <section style="background: var(--surface-alt); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
    <div class="container-page py-14 reveal">
      <div class="mb-8 text-center">
        <p class="font-mono text-xs mb-1" style="color: var(--primary);">$ man ctf</p>
        <h2 class="text-2xl font-bold tracking-tight" style="color: var(--text);">¿Cómo funciona?</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 stagger-children">
        {steps.map(step => (
          <div class="flex flex-col items-center text-center">
            <div class="relative mb-4">
              <span
                class="inline-flex items-center justify-center w-12 h-12 rounded-full"
                style="background: var(--primary-light); color: var(--primary); border: 1px solid var(--primary-border);"
                set:html={step.icon}
              />
              <span
                class="absolute -top-1.5 -right-1.5 text-[10px] font-mono font-black w-5 h-5 flex items-center justify-center rounded-full"
                style="background: var(--primary); color: white;"
              >
                {step.n.slice(1)}
              </span>
            </div>
            <p class="font-bold text-sm mb-1.5" style="color: var(--text);">{step.title}</p>
            <p class="text-xs leading-relaxed" style="color: var(--text-muted);">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ RETOS DESTACADOS -->
  <section class="container-page py-16 reveal">
    <div class="flex items-end justify-between mb-6">
      <div>
        <p class="font-mono text-xs mb-1" style="color: var(--primary);">$ grep -r "flag" ./challenges/</p>
        <h2 class="text-2xl font-bold tracking-tight" style="color: var(--text);">Retos destacados</h2>
      </div>
      <a href="/challenges" class="text-xs font-semibold hover:underline hidden sm:inline-flex items-center gap-1" style="color: var(--primary);">
        Ver los 14 retos
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>

    <div class="divide-y rounded-xl overflow-hidden stagger-children" style="border: 1px solid var(--border); --tw-divide-opacity: 1;">
      {featured.map(ch => (
        <a
          href={`/challenges/${ch.slug}`}
          class="challenge-row group"
          aria-label={`Reto ${ch.title}, ${ch.pts} puntos`}
        >
          <div class="flex items-start gap-3.5 min-w-0">
            <span
              class="inline-block shrink-0 text-[11px] font-bold px-2 py-1 rounded mt-0.5 font-mono"
              style={`background: rgba(${ch.color === '#818cf8' ? '129,140,248' : ch.color === '#f472b6' ? '244,114,182' : '52,211,153'},0.1); color: ${ch.color}; border: 1px solid rgba(${ch.color === '#818cf8' ? '129,140,248' : ch.color === '#f472b6' ? '244,114,182' : '52,211,153'},0.25);`}
            >
              {ch.label}
            </span>
            <div class="min-w-0">
              <p class="font-semibold text-sm" style="color: var(--text);">{ch.title}</p>
              <p class="text-xs mt-0.5 truncate" style="color: var(--text-muted);">{ch.desc}</p>
            </div>
          </div>
          <div class="flex items-center gap-3 shrink-0">
            <span class="text-xs font-mono font-bold" style="color: var(--primary);">{ch.pts} pt</span>
            <svg class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" style="color: var(--primary);">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>
      ))}
    </div>

    <p class="text-right mt-3 sm:hidden">
      <a href="/challenges" class="text-xs font-semibold hover:underline" style="color: var(--primary);">
        Ver los 14 retos →
      </a>
    </p>
  </section>

  <!-- ══════════════════════════════════════════════════════ CTA FINAL -->
  <section class="reveal" style="background: radial-gradient(ellipse at 40% 50%, #3d2c88 0%, #1a0f40 100%); border-top: 1px solid rgba(99,102,241,0.2);">
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none"
      style="background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 32px 32px;">
    </div>
    <div class="container-page relative py-16 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8">
      <div class="text-white">
        <p class="font-mono text-xs mb-2" style="color: rgba(255,238,88,0.6);">$ sudo ./register.sh</p>
        <h2 class="text-2xl font-bold tracking-tight mb-2">¿Listo para competir?</h2>
        <p class="text-sm leading-relaxed max-w-md" style="color: rgba(255,255,255,0.55);">
          Sin instalaciones, sin configuración. Crea tu cuenta y empieza a resolver retos en segundos.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3 shrink-0">
        <HomeRegisterBtn client:load />
        <a href="/challenges" class="hero-cta-outline text-sm">
          Explorar retos
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
